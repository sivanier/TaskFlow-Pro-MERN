{
  "name": "task-management-application",
  "version": "1.0.0",
  "description": "Full-stack task management web application built with React, Express, and a JSON database.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
